// Content Smuggler — Full Backend Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== AUTH & USERS =====

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?
  name          String?
  username      String?   @unique
  passwordHash  String?
  avatar        String?
  bio           String?
  country       String?
  timezone      String?
  language      String    @default("English")
  creatorCategory String?
  role          String    @default("user") // user | admin
  plan          String    @default("starter") // starter | creator | agency
  planRenewsAt  DateTime?
  usageCount    Int       @default(0)
  usageLimit    Int       @default(10)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  socialAccounts  SocialAccount[]
  generatedItems  GeneratedItem[]
  folders         Folder[]
  goals           Goal[]
  activities      Activity[]
  apiKeys         ApiKey[]
  teamMembers     TeamMember[]
  notifications   Notification[]
  sessions        Session[]
  invoices        Invoice[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  device       String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ===== SOCIAL ACCOUNTS =====

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String   // youtube | instagram | tiktok | twitter | facebook | linkedin | twitch | pinterest | reddit | discord
  username    String?
  avatar      String?
  followers   Int      @default(0)
  views       Int      @default(0)
  subscribers Int      @default(0)
  engagement  Float    @default(0)
  lastSync    DateTime?
  health      String   @default("good") // good | warning | error
  accessToken String?
  refreshToken String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_accounts")
}

// ===== LIBRARY (Generated Content + Folders) =====

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#C09858")
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedItems GeneratedItem[]
  parent         Folder?         @relation("FolderHierarchy", fields: [parentId], references: [id])
  children       Folder[]        @relation("FolderHierarchy")

  @@map("folders")
}

model GeneratedItem {
  id          String   @id @default(cuid())
  userId      String
  toolId      String
  toolName    String
  title       String
  content     String
  type        String   // hook | title | script | caption | thumbnail | ai-output | etc.
  category    String?
  score       Int?
  summary     String?
  metrics     String?  // JSON string
  tags        String?  // JSON array as string
  favorite    Boolean  @default(false)
  pinned      Boolean  @default(false)
  status      String   @default("active") // active | draft | archived | trash
  folderId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@map("generated_items")
}

// ===== STUDIO (Goals + Activities) =====

model Goal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  current   Int      @default(0)
  target    Int
  unit      String
  color     String   @default("#C09858")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  action    String   // generated | saved | exported | created | edited | deleted
  itemTitle String
  itemType  String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

// ===== BILLING =====

model Invoice {
  id           String   @id @default(cuid())
  userId       String
  amount       Float
  currency     String   @default("USD")
  status       String   @default("paid") // paid | pending | failed
  invoiceNo    String?
  downloadUrl  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ===== TEAM =====

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String?
  role      String   @default("viewer") // admin | editor | viewer
  avatar    String?
  status    String   @default("invited") // active | invited
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

// ===== API KEYS =====

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  key       String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ===== NOTIFICATIONS =====

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // growth | ai_suggestion | publishing | trending | revenue | tool
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}
