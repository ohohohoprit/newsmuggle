// Content Smuggler — Full Backend Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===== AUTH & USERS =====

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  phone             String?   @unique
  name              String?
  username          String?   @unique
  passwordHash      String?
  avatar            String?
  bio               String?
  country           String?
  timezone          String?
  language          String    @default("English")
  creatorCategory   String?
  role              String    @default("user") // user | admin
  plan              String    @default("starter") // starter | creator | agency
  planRenewsAt      DateTime?
  usageCount        Int       @default(0)
  usageLimit        Int       @default(10)
  onboardingCompleted Boolean  @default(false)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  loginCount        Int       @default(0)
  activeWorkspaceId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  socialAccounts    SocialAccount[]
  generatedItems    GeneratedItem[]
  folders           Folder[]
  goals             Goal[]
  activities        Activity[]
  apiKeys           ApiKey[]
  teamMembers       TeamMember[]
  notifications     Notification[]
  invoices          Invoice[]
  auditLogs         AuditLog[]

  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  activeWorkspace      Workspace?        @relation("UserActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  toolExecutions       ToolExecution[]

  @@map("users")
}

// ===== WORKSPACES =====

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  type        String   @default("personal") // personal | team
  ownerId     String
  avatar      String?
  settings    String?  // JSON-encoded settings blob
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  activeForUsers User[]           @relation("UserActiveWorkspace")
  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  toolExecutions ToolExecution[]
  toolQuotas    ToolUsageQuota[]

  @@index([ownerId])
  @@index([type])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("viewer") // owner | admin | editor | viewer
  status      String   @default("active") // active | invited | removed
  invitedBy   String?
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  token       String    @unique
  role        String    @default("viewer") // admin | editor | viewer (never owner)
  invitedBy   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  acceptedBy  String?
  revokedAt   DateTime?
  revokedBy   String?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
  @@map("workspace_invites")
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  provider          String    // google | facebook | credentials
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  device       String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  identifier String  // email or phone
  type      String   // email_verification | password_reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("verification_tokens")
}

model OtpChallenge {
  id           String   @id @default(cuid())
  identifier   String   // phone number
  codeHash     String
  attempts     Int      @default(0)
  maxAttempts  Int      @default(5)
  resendCount  Int      @default(0)
  maxResends   Int      @default(3)
  expiresAt    DateTime
  consumed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([identifier])
  @@map("otp_challenges")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // login | logout | register | otp_send | otp_verify | google_login | password_change
  ip        String?
  userAgent String?
  status    String   @default("success") // success | failed
  meta      String?  // JSON string
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ===== SOCIAL ACCOUNTS =====

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  username    String?
  avatar      String?
  followers   Int      @default(0)
  views       Int      @default(0)
  subscribers Int      @default(0)
  engagement  Float    @default(0)
  lastSync    DateTime?
  health      String   @default("good")
  accessToken String?
  refreshToken String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_accounts")
}

// ===== LIBRARY =====

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#C09858")
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedItems GeneratedItem[]
  parent         Folder?         @relation("FolderHierarchy", fields: [parentId], references: [id])
  children       Folder[]        @relation("FolderHierarchy")

  @@map("folders")
}

model GeneratedItem {
  id          String   @id @default(cuid())
  userId      String
  toolId      String
  toolName    String
  title       String
  content     String
  type        String
  category    String?
  score       Int?
  summary     String?
  metrics     String?
  tags        String?
  favorite    Boolean  @default(false)
  pinned      Boolean  @default(false)
  status      String   @default("active")
  folderId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@map("generated_items")
}

// ===== STUDIO =====

model Goal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  current   Int      @default(0)
  target    Int
  unit      String
  color     String   @default("#C09858")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  itemTitle String
  itemType  String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

// ===== BILLING =====

model Invoice {
  id           String   @id @default(cuid())
  userId       String
  amount       Float
  currency     String   @default("USD")
  status       String   @default("paid")
  invoiceNo    String?
  downloadUrl  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ===== TEAM =====

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String?
  role      String   @default("viewer")
  avatar    String?
  status    String   @default("invited")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

// ===== API KEYS =====

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  key       String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ===== NOTIFICATIONS =====

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  actionUrl String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// ===== TOOL REGISTRY =====

model ToolCategory {
  id          String   @id @default(cuid())
  slug        String   @unique // writing | seo | video | social-media | repurposing | analytics | planning | business | ai-utility
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tools ToolDefinition[]

  @@map("tool_categories")
}

model ToolDefinition {
  id              String   @id @default(cuid())
  slug            String   @unique // hook-generator | title-optimizer | ...
  name            String
  description     String
  categoryId      String
  icon            String?
  agentTip        String?
  outputFormat    String   @default("items") // text | json | items | structured
  outputLabel     String   @default("Your Generated Results")
  outputItemNoun  String   @default("result")
  analysisTitle   String   @default("Why these results work?")
  inputSchema     String   // JSON: array of field configs
  outputSchema    String?  // JSON: optional output schema descriptor
  promptTemplate  String   // system + user prompt template with {{var}} placeholders
  modelConfig     String   @default("{\"provider\":\"zai\",\"model\":\"default\",\"temperature\":0.8}")
  defaultCount    Int      @default(5)
  countOptions    String   @default("[1,3,5,10,15,20]")
  minPlan         String   @default("starter") // starter | creator | agency
  usageLimit      Int      @default(0) // per-workspace per-month; 0 = use plan default
  tags            String?  // JSON array of tags
  isPopular       Boolean  @default(false)
  isNew           Boolean  @default(false)
  isEnabled       Boolean  @default(true)
  isSystem        Boolean  @default(true) // system tools can't be deleted via admin API
  sortOrder       Int      @default(0)
  version         Int      @default(1)
  examples        String?  // JSON array of example input/output pairs
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category    ToolCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  executions  ToolExecution[]
  presets     ToolPreset[]

  @@index([categoryId])
  @@index([isEnabled])
  @@index([slug])
  @@map("tool_definitions")
}

model ToolPreset {
  id          String   @id @default(cuid())
  toolId      String
  name        String
  description String?
  inputs      String   // JSON: preset input values
  isPublic    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tool ToolDefinition @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([createdBy])
  @@map("tool_presets")
}

model ToolExecution {
  id              String   @id @default(cuid())
  toolId          String
  userId          String
  workspaceId     String
  inputs          String   // JSON: the inputs that were run
  outputFormat    String   // text | json | items | structured
  output          String   // JSON: the full structured result
  summary         String?
  metrics         String?  // JSON: quality metrics
  status          String   @default("success") // success | failed | partial
  errorMessage     String?
  modelConfig     String?  // JSON: the model config used
  latencyMs       Int      @default(0)
  tokenUsage      Int      @default(0)
  createdAt       DateTime @default(now())

  tool      ToolDefinition @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([status])
  @@map("tool_executions")
}

model ToolUsageQuota {
  id          String   @id @default(cuid())
  workspaceId String
  toolId      String?
  periodStart DateTime // first day of the month (UTC)
  periodEnd   DateTime // last day of the month (UTC)
  used        Int      @default(0)
  limit       Int      @default(0) // 0 = unlimited
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, toolId, periodStart])
  @@index([workspaceId, periodStart])
  @@map("tool_usage_quotas")
}
