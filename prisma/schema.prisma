// Content Smuggler — Full Backend Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== AUTH & USERS =====

model User {
  id                String    @id @default(cuid())
  email             String?   @unique
  phone             String?   @unique
  name              String?
  username          String?   @unique
  passwordHash      String?
  avatar            String?
  bio               String?
  country           String?
  timezone          String?
  language          String    @default("English")
  creatorCategory   String?
  role              String    @default("user") // user | admin
  plan              String    @default("starter") // starter | creator | agency (mirror of active workspace subscription plan)
  planRenewsAt      DateTime?
  usageCount        Int       @default(0)
  usageLimit        Int       @default(10)
  onboardingCompleted Boolean  @default(false)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  loginCount        Int       @default(0)
  activeWorkspaceId String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  socialAccounts    SocialAccount[]
  generatedItems    GeneratedItem[]
  folders           Folder[]
  goals             Goal[]
  activities        Activity[]
  apiKeys           ApiKey[]
  teamMembers       TeamMember[]
  notifications     Notification[]
  invoices          Invoice[]
  auditLogs         AuditLog[]

  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  activeWorkspace      Workspace?        @relation("UserActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  toolExecutions       ToolExecution[]
  billingEvents        BillingEvent[]
  notificationPreferences NotificationPreference[]
  notificationEvents   NotificationEvent[]

  @@map("users")
}

// ===== WORKSPACES =====

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  type        String   @default("personal") // personal | team
  ownerId     String
  avatar      String?
  settings    String?  // JSON-encoded settings blob
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  activeForUsers User[]           @relation("UserActiveWorkspace")
  members       WorkspaceMember[]
  invites       WorkspaceInvite[]
  toolExecutions ToolExecution[]
  toolQuotas    ToolUsageQuota[]
  subscription  Subscription?
  invoices      Invoice[]
  billingEvents BillingEvent[]
  usageSnapshots UsageSnapshot[]
  quotaSyncJobs  QuotaSyncJob[]
  connectedAccounts ConnectedAccount[]
  studioSyncJobs    StudioSyncJob[]
  notifications     Notification[]
  notificationEvents NotificationEvent[]
  thresholdAlerts   UsageThresholdAlert[]
  fileAssets        FileAsset[]
  exportJobs        ExportJob[]

  @@index([ownerId])
  @@index([type])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("viewer") // owner | admin | editor | viewer
  status      String   @default("active") // active | invited | removed
  invitedBy   String?
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String    @id @default(cuid())
  workspaceId String
  email       String
  token       String    @unique
  role        String    @default("viewer") // admin | editor | viewer (never owner)
  invitedBy   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  acceptedBy  String?
  revokedAt   DateTime?
  revokedBy   String?
  createdAt   DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([email])
  @@index([token])
  @@map("workspace_invites")
}

model Account {
  id                String    @id @default(cuid())
  userId            String
  provider          String    // google | facebook | credentials
  providerAccountId String
  refreshToken      String?
  accessToken       String?
  expiresAt         DateTime?
  tokenType         String?
  scope             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  device       String?
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  identifier String  // email or phone
  type      String   // email_verification | password_reset
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("verification_tokens")
}

model OtpChallenge {
  id           String   @id @default(cuid())
  identifier   String   // phone number
  codeHash     String
  attempts     Int      @default(0)
  maxAttempts  Int      @default(5)
  resendCount  Int      @default(0)
  maxResends   Int      @default(3)
  expiresAt    DateTime
  consumed     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([identifier])
  @@map("otp_challenges")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // login | logout | register | otp_send | otp_verify | google_login | password_change
  ip        String?
  userAgent String?
  status    String   @default("success") // success | failed
  meta      String?  // JSON string
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

// ===== SOCIAL ACCOUNTS =====

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  platform    String
  username    String?
  avatar      String?
  followers   Int      @default(0)
  views       Int      @default(0)
  subscribers Int      @default(0)
  engagement  Float    @default(0)
  lastSync    DateTime?
  health      String   @default("good")
  accessToken String?
  refreshToken String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
  @@map("social_accounts")
}

// ===== LIBRARY =====

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#C09858")
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedItems GeneratedItem[]
  parent         Folder?         @relation("FolderHierarchy", fields: [parentId], references: [id])
  children       Folder[]        @relation("FolderHierarchy")

  @@map("folders")
}

model GeneratedItem {
  id          String   @id @default(cuid())
  userId      String
  toolId      String
  toolName    String
  title       String
  content     String
  type        String
  category    String?
  score       Int?
  summary     String?
  metrics     String?
  tags        String?
  favorite    Boolean  @default(false)
  pinned      Boolean  @default(false)
  status      String   @default("active")
  folderId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@map("generated_items")
}

// ===== STUDIO =====

model Goal {
  id        String   @id @default(cuid())
  userId    String
  title     String
  current   Int      @default(0)
  target    Int
  unit      String
  color     String   @default("#C09858")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  action    String
  itemTitle String
  itemType  String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activities")
}

// ===== BILLING & SUBSCRIPTION =====

model Plan {
  id              String   @id @default(cuid())
  slug            String   @unique // starter | creator | agency
  name            String
  description     String?
  priceMonthly    Int      @default(0) // in cents (USD)
  priceYearly     Int      @default(0) // in cents (USD)
  currency        String   @default("usd")
  maxGenerations  Int      @default(10) // monthly AI generation limit
  maxTools        Int      @default(5) // max enabled custom tools
  maxStorage      Int      @default(1) // GB
  teamSeats       Int      @default(0)
  apiAccess       Boolean  @default(false)
  whiteLabel      Boolean  @default(false)
  features        String?  // JSON: additional feature flags
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?
  razorpayPlanIdMonthly String?
  razorpayPlanIdYearly  String?
  isPublic        Boolean  @default(true)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                    String    @id @default(cuid())
  workspaceId           String    @unique // one subscription per workspace
  planId                String
  status                String    @default("trialing") // trialing | active | past_due | canceled | incomplete | paused
  interval              String    @default("monthly") // monthly | yearly
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  canceledAt            DateTime?
  trialEnd              DateTime?
  provider              String?   // stripe | razorpay | none (for manual/free)
  providerSubscriptionId String?  // Stripe subscription ID or Razorpay subscription ID
  providerCustomerId    String?   // Stripe customer ID or Razorpay customer ID
  providerStatus        String?   // provider-specific status string
  providerMetadata      String?   // JSON: provider-specific metadata
  startedAt             DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@index([status])
  @@index([provider])
  @@map("subscriptions")
}

model BillingEvent {
  id                String   @id @default(cuid())
  workspaceId       String
  userId            String?
  type              String   // subscription_created | subscription_renewed | subscription_upgraded | subscription_downgraded | subscription_canceled | payment_succeeded | payment_failed | invoice_generated | quota_reset | usage_threshold_reached
  provider          String?  // stripe | razorpay | system
  providerEventId   String?  // idempotency key — provider's event/charge ID
  status            String   @default("processed") // received | processing | processed | failed
  payload           String   // JSON: full event payload (sanitized)
  errorMessage      String?
  processedAt       DateTime?
  createdAt         DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([workspaceId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("billing_events")
}

model Invoice {
  id                    String    @id @default(cuid())
  workspaceId           String
  userId                String?
  subscriptionId        String?
  amount                Int       @default(0) // in cents (USD)
  currency              String    @default("usd")
  status                String    @default("open") // draft | open | paid | void | uncollectible
  invoiceNo             String?
  description           String?
  periodStart           DateTime?
  periodEnd             DateTime?
  provider              String?   // stripe | razorpay | none
  providerInvoiceId     String?   // Stripe invoice ID or Razorpay invoice ID
  providerPaymentId     String?   // Stripe charge/payment_intent ID or Razorpay payment ID
  hostedInvoiceUrl      String?
  invoicePdfUrl         String?
  paidAt                DateTime?
  attemptCount          Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([userId])
  @@index([status])
  @@index([provider])
  @@map("invoices")
}

model UsageSnapshot {
  id              String   @id @default(cuid())
  workspaceId     String
  periodStart     DateTime // first day of the month (UTC)
  periodEnd       DateTime // last day of the month (UTC)
  planSlug        String
  generationsUsed Int      @default(0)
  generationsLimit Int     @default(0)
  tokensUsed      Int      @default(0)
  costUsd         Float    @default(0)
  storageUsedMb   Int      @default(0)
  teamSeatsUsed   Int      @default(0)
  snapshotData    String?  // JSON: detailed breakdown
  createdAt       DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, periodStart])
  @@index([workspaceId, periodStart])
  @@map("usage_snapshots")
}

model QuotaSyncJob {
  id              String   @id @default(cuid())
  workspaceId     String
  type            String   // usage_sync | quota_reset | invoice_generate | threshold_check
  status          String   @default("pending") // pending | running | completed | failed
  periodStart     DateTime?
  periodEnd       DateTime?
  scheduledFor    DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  result          String?  // JSON: job result data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([type, status])
  @@index([scheduledFor])
  @@map("quota_sync_jobs")
}

// ===== TEAM =====

model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  email     String
  name      String?
  role      String   @default("viewer")
  avatar    String?
  status    String   @default("invited")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

// ===== API KEYS =====

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  key       String    @unique
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ===== NOTIFICATIONS =====

model Notification {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String?
  type        String    // billing | studio | quota | system | tool | workspace
  category    String    @default("general") // subscription | payment | usage | sync | account | security | general
  priority    String    @default("normal") // low | normal | high | urgent
  title       String
  message     String
  actionUrl   String?
  read        Boolean   @default(false)
  readAt      DateTime?
  metadata    String?   // JSON: additional structured data
  dedupKey    String?   // deduplication key — if set, prevents duplicate notifications
  createdAt   DateTime  @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, read])
  @@index([workspaceId, createdAt])
  @@index([type, createdAt])
  @@index([category, createdAt])
  @@index([dedupKey])
  @@map("notifications")
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String
  category        String   // subscription | payment | usage | sync | account | security | general
  inAppEnabled    Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  webhookEnabled  Boolean  @default(false)
  minPriority     String   @default("low") // only notify for priority >= minPriority
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("notification_preferences")
}

model NotificationDelivery {
  id              String   @id @default(cuid())
  notificationId  String
  channel         String   // in_app | email | webhook
  status          String   @default("pending") // pending | sent | failed | skipped
  recipient       String?  // email address or webhook URL
  providerMessageId String? // provider's message ID (email/webhook)
  attemptCount    Int      @default(0)
  maxAttempts     Int      @default(3)
  lastAttemptAt   DateTime?
  nextAttemptAt   DateTime?
  errorMessage    String?
  payload         String?  // JSON: the delivered payload
  sentAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([status, nextAttemptAt])
  @@index([channel, status])
  @@map("notification_deliveries")
}

model NotificationEvent {
  id              String   @id @default(cuid())
  workspaceId     String?
  userId          String?
  eventType       String   // billing.subscription_created | billing.payment_failed | studio.sync_completed | quota.threshold_reached | etc.
  source          String   // billing | studio | quota | system | tool
  payload         String   // JSON: event data
  notificationId  String?  // the notification created from this event (if any)
  processedAt     DateTime?
  createdAt       DateTime @default(now())

  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([eventType, createdAt])
  @@index([source, createdAt])
  @@map("notification_events")
}

// ===== TOOL REGISTRY =====

model ToolCategory {
  id          String   @id @default(cuid())
  slug        String   @unique // writing | seo | video | social-media | repurposing | analytics | planning | business | ai-utility
  name        String
  description String?
  icon        String?
  color       String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tools ToolDefinition[]

  @@map("tool_categories")
}

model ToolDefinition {
  id              String   @id @default(cuid())
  slug            String   @unique // hook-generator | title-optimizer | ...
  name            String
  description     String
  categoryId      String
  icon            String?
  agentTip        String?
  outputFormat    String   @default("items") // text | json | items | structured
  outputLabel     String   @default("Your Generated Results")
  outputItemNoun  String   @default("result")
  analysisTitle   String   @default("Why these results work?")
  inputSchema     String   // JSON: array of field configs
  outputSchema    String?  // JSON: optional output schema descriptor
  promptTemplate  String   // system + user prompt template with {{var}} placeholders
  modelConfig     String   @default("{\"provider\":\"zai\",\"model\":\"default\",\"temperature\":0.8}")
  defaultCount    Int      @default(5)
  countOptions    String   @default("[1,3,5,10,15,20]")
  minPlan         String   @default("starter") // starter | creator | agency
  usageLimit      Int      @default(0) // per-workspace per-month; 0 = use plan default
  tags            String?  // JSON array of tags
  isPopular       Boolean  @default(false)
  isNew           Boolean  @default(false)
  isEnabled       Boolean  @default(true)
  isSystem        Boolean  @default(true) // system tools can't be deleted via admin API
  sortOrder       Int      @default(0)
  version         Int      @default(1)
  examples        String?  // JSON array of example input/output pairs
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category    ToolCategory    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  executions  ToolExecution[]
  presets     ToolPreset[]

  @@index([categoryId])
  @@index([isEnabled])
  @@index([slug])
  @@map("tool_definitions")
}

model ToolPreset {
  id          String   @id @default(cuid())
  toolId      String
  name        String
  description String?
  inputs      String   // JSON: preset input values
  isPublic    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tool ToolDefinition @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([createdBy])
  @@map("tool_presets")
}

model ToolExecution {
  id              String   @id @default(cuid())
  toolId          String
  userId          String
  workspaceId     String
  inputs          String   // JSON: the inputs that were run
  outputFormat    String   // text | json | items | structured
  output          String   // JSON: the full structured result
  summary         String?
  metrics         String?  // JSON: quality metrics
  status          String   @default("success") // success | failed | partial
  errorMessage     String?
  modelConfig     String?  // JSON: the model config used
  provider        String?  // zai | gemini | openai | claude | grok | deepseek
  model           String?  // the actual model name used (resolved)
  latencyMs       Int      @default(0)
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  totalTokens     Int      @default(0)
  tokenUsage      Int      @default(0) // legacy alias kept for backward compat
  costUsd         Float    @default(0)
  retries         Int      @default(0)
  createdAt       DateTime @default(now())

  tool      ToolDefinition @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
  @@index([status])
  @@index([provider])
  @@map("tool_executions")
}

model ToolUsageQuota {
  id          String   @id @default(cuid())
  workspaceId String
  toolId      String?
  periodStart DateTime // first day of the month (UTC)
  periodEnd   DateTime // last day of the month (UTC)
  used        Int      @default(0)
  limit       Int      @default(0) // 0 = unlimited
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, toolId, periodStart])
  @@index([workspaceId, periodStart])
  @@map("tool_usage_quotas")
}

// ===== CREATOR STUDIO =====

model ConnectedAccount {
  id              String    @id @default(cuid())
  workspaceId     String
  provider        String    // youtube | instagram | facebook | tiktok
  providerAccountId String  // platform's channel/user ID
  handle          String?   // @username or channel handle
  displayName     String?
  avatar          String?
  description     String?
  accountType     String    @default("personal") // personal | business | creator
  followerCount   Int       @default(0)
  followingCount  Int       @default(0)
  totalViews      Int       @default(0)
  totalPosts      Int       @default(0)
  isVerified      Boolean   @default(false)
  isConnected     Boolean   @default(true)
  accessToken     String?   // encrypted in production
  refreshToken    String?
  tokenExpiresAt  DateTime?
  tokenScope      String?   // JSON: granted scopes
  connectedById   String
  lastSyncedAt    DateTime?
  syncStatus      String    @default("pending") // pending | syncing | synced | failed | stale
  syncCursor      String?   // JSON: cursor for incremental sync
  providerMetadata String?  // JSON: provider-specific data
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentItems    SocialContentItem[]
  metricSnapshots SocialMetricSnapshot[]
  audienceSnapshots SocialAudienceSnapshot[]
  syncFailures    SyncFailureLog[]
  syncJobs        StudioSyncJob[]

  @@unique([workspaceId, provider, providerAccountId])
  @@index([workspaceId, provider])
  @@index([syncStatus])
  @@map("connected_accounts")
}

model SocialContentItem {
  id              String   @id @default(cuid())
  connectedAccountId String
  providerContentId String  // platform's video/post ID
  type            String   // video | post | reel | story | short
  title           String?
  description     String?
  thumbnailUrl    String?
  contentUrl      String?
  publishedAt     DateTime
  durationSeconds Int?
  viewCount       Int      @default(0)
  likeCount       Int      @default(0)
  commentCount    Int      @default(0)
  shareCount      Int      @default(0)
  engagementRate  Float    @default(0)
  tags            String?  // JSON array
  metadata        String?  // JSON: provider-specific data
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@unique([connectedAccountId, providerContentId])
  @@index([connectedAccountId, publishedAt])
  @@index([connectedAccountId, type])
  @@map("social_content_items")
}

model SocialMetricSnapshot {
  id              String   @id @default(cuid())
  connectedAccountId String
  snapshotDate    DateTime  // the date this snapshot represents (UTC midnight)
  followerCount   Int      @default(0)
  followingCount  Int      @default(0)
  totalViews      Int      @default(0)
  totalPosts      Int      @default(0)
  newFollowers    Int      @default(0)  // gained since last snapshot
  newViews        Int      @default(0)
  newPosts        Int      @default(0)
  avgEngagementRate Float  @default(0)
  estimatedReach  Int      @default(0)
  metadata        String?  // JSON: additional metrics
  createdAt       DateTime @default(now())

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@unique([connectedAccountId, snapshotDate])
  @@index([connectedAccountId, snapshotDate])
  @@map("social_metric_snapshots")
}

model SocialAudienceSnapshot {
  id              String   @id @default(cuid())
  connectedAccountId String
  snapshotDate    DateTime  // UTC midnight
  ageRange        String?  // e.g. "18-24"
  gender          String?  // male | female | other
  country         String?
  city            String?
  percentage      Float    @default(0)  // % of audience in this segment
  count           Int      @default(0)
  metadata        String?  // JSON: additional demographic data
  createdAt       DateTime @default(now())

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([connectedAccountId, snapshotDate])
  @@index([connectedAccountId, country])
  @@map("social_audience_snapshots")
}

model StudioSyncJob {
  id              String   @id @default(cuid())
  workspaceId     String
  connectedAccountId String?
  provider        String   // youtube | instagram | all
  type            String   // full | incremental | metrics | content | audience
  status          String   @default("pending") // pending | running | completed | failed | partial
  triggeredBy     String   // system | user | webhook
  userId          String?  // who triggered (if user)
  startedAt       DateTime?
  completedAt     DateTime?
  errorMessage    String?
  result          String?  // JSON: { itemsSynced, snapshotsCreated, failures }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connectedAccount ConnectedAccount? @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([provider, status])
  @@index([type, status])
  @@index([createdAt])
  @@map("studio_sync_jobs")
}

model SyncFailureLog {
  id              String   @id @default(cuid())
  connectedAccountId String
  syncJobId       String?
  errorType       String   // auth_error | rate_limit | network | provider_error | parse_error
  errorMessage    String
  errorCode       String?
  statusCode      Int?
  payload         String?  // JSON: request/response context
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  connectedAccount ConnectedAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Cascade)

  @@index([connectedAccountId, createdAt])
  @@index([errorType])
  @@index([resolvedAt])
  @@map("sync_failure_logs")
}

// ===== CRON JOBS & SCHEDULER =====

model JobRun {
  id              String    @id @default(cuid())
  jobType         String    // quota_reset | usage_snapshot | threshold_check | stale_check | studio_sync | notification_cleanup | retry_failed
  status          String    @default("running") // running | completed | failed | partial
  triggeredBy     String    @default("system") // system | user | cron
  userId          String?   // who triggered (if user)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  durationMs      Int       @default(0)
  errorMessage    String?
  result          String?   // JSON: { processed, created, failed, ... }
  metadata        String?   // JSON: job-specific data
  createdAt       DateTime  @default(now())

  @@index([jobType, status])
  @@index([jobType, createdAt])
  @@index([status, createdAt])
  @@map("job_runs")
}

model JobCursor {
  id              String   @id @default(cuid())
  jobType         String   @unique
  lastRunAt       DateTime?
  lastRunDate     String?  // YYYY-MM-DD — used for daily dedup
  lastCursor      String?  // JSON: cursor data (e.g. last processed workspaceId)
  runCount        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("job_cursors")
}

model JobFailureLog {
  id              String   @id @default(cuid())
  jobRunId        String?
  jobType         String
  errorType       String   // auth_error | rate_limit | network | provider_error | internal_error
  errorMessage    String
  errorCode       String?
  statusCode      Int?
  payload         String?  // JSON: context data
  resolvedAt      DateTime?
  retryCount      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([jobType, resolvedAt])
  @@index([errorType])
  @@index([createdAt])
  @@map("job_failure_logs")
}

model UsageThresholdAlert {
  id              String   @id @default(cuid())
  workspaceId     String
  threshold       Int      // 80 | 90 | 100
  percentUsed     Float
  used            Int
  limit           Int
  planSlug        String
  alertKey        String   // dedup key: workspaceId:threshold:period
  notifiedAt      DateTime @default(now())
  resolvedAt      DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([alertKey])
  @@index([workspaceId, notifiedAt])
  @@index([threshold, notifiedAt])
  @@index([resolvedAt])
  @@map("usage_threshold_alerts")
}

// ===== SECURITY & MONITORING =====

model SecurityEvent {
  id              String   @id @default(cuid())
  userId          String?
  workspaceId     String?
  eventType       String   // rate_limit_hit | abuse_detected | suspicious_pattern | auth_failure_burst | blocked_request | permission_denied | invalid_input_burst
  severity        String   @default("low") // low | medium | high | critical
  ip              String?
  userAgent       String?
  path            String?
  method          String?
  riskScore      Int      @default(0) // 0-100
  payload         String?  // JSON: event details
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([eventType, createdAt])
  @@index([severity, createdAt])
  @@index([resolvedAt])
  @@map("security_events")
}

model RateLimitBucket {
  id              String   @id @default(cuid())
  key             String   @unique // ip:<addr> | user:<id> | workspace:<id> | route:<path>:<ip>
  tokens          Float    @default(0)
  maxTokens       Int      @default(100)
  refillRate      Float    @default(1) // tokens per second
  lastRefillAt    DateTime @default(now())
  blockedUntil    DateTime?
  blockCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("rate_limit_buckets")
}

model CacheEntry {
  id              String   @id @default(cuid())
  key             String   @unique // namespace:identifier
  value           String   // JSON-serialized value
  ttlSeconds      Int      @default(60)
  expiresAt       DateTime
  hitCount        Int      @default(0)
  sizeBytes       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
  @@index([key])
  @@map("cache_entries")
}

model HealthCheckLog {
  id              String   @id @default(cuid())
  checkType       String   // liveness | readiness | dependency
  serviceName     String   // database | ai_provider | billing | studio | notifications
  status          String   // healthy | degraded | unhealthy
  latencyMs       Int      @default(0)
  errorMessage    String?
  metadata        String?  // JSON
  createdAt       DateTime @default(now())

  @@index([checkType, createdAt])
  @@index([serviceName, status, createdAt])
  @@map("health_check_logs")
}

model MetricSnapshot {
  id              String   @id @default(cuid())
  metricType      String   // request_latency | error_count | job_success | job_failure | active_users | api_calls
  periodStart     DateTime
  periodEnd       DateTime
  period          String   // minute | hour | day
  count           Int      @default(0)
  sum             Float    @default(0)
  avg             Float    @default(0)
  min             Float    @default(0)
  max             Float    @default(0)
  p50             Float    @default(0)
  p95             Float    @default(0)
  p99             Float    @default(0)
  metadata        String?  // JSON: tags, labels
  createdAt       DateTime @default(now())

  @@unique([metricType, period, periodStart])
  @@index([metricType, periodStart])
  @@map("metric_snapshots")
}

model ServiceIncident {
  id              String   @id @default(cuid())
  title           String
  description     String?
  severity        String   @default("warning") // info | warning | critical | maintenance
  status          String   @default("open") // open | monitoring | resolved | postmortem
  serviceName     String?  // database | ai_provider | billing | studio | notifications | global
  startedAt       DateTime @default(now())
  resolvedAt      DateTime?
  affectedUsers   Int      @default(0)
  metadata        String?  // JSON
  createdById     String?
  resolvedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, severity])
  @@index([serviceName, status])
  @@index([startedAt])
  @@map("service_incidents")
}

model AuditQueryLog {
  id              String   @id @default(cuid())
  queriedById     String
  queryFilters    String   // JSON: the filters used
  resultCount     Int      @default(0)
  ipAddress       String?
  createdAt       DateTime @default(now())

  @@index([queriedById, createdAt])
  @@map("audit_query_logs")
}

model AbuseDetectionFlag {
  id              String   @id @default(cuid())
  userId          String?
  workspaceId     String?
  ip              String?
  flagType        String   // rapid_requests | failed_auth_burst | excessive_tool_runs | quota_abuse | suspicious_pattern
  riskScore       Int      @default(0) // 0-100
  evidence        String?  // JSON: detection details
  autoBlocked     Boolean  @default(false)
  blockedUntil    DateTime?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?  // false_positive | confirmed | escalated
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, resolvedAt])
  @@index([workspaceId, resolvedAt])
  @@index([ip, resolvedAt])
  @@index([flagType, resolvedAt])
  @@index([riskScore])
  @@map("abuse_detection_flags")
}

// ===== EXPORT & FILES =====

model FileAsset {
  id              String    @id @default(cuid())
  workspaceId     String
  uploadedById    String
  filename        String
  originalName    String?
  mimeType        String    @default("application/octet-stream")
  sizeBytes       Int       @default(0)
  storageKey      String    // path/key in storage provider
  storageProvider String    @default("local") // local | s3 | r2 | gcs
  category        String    @default("general") // upload | export | generated | studio
  sourceType      String?   // tool_execution | studio_content | manual_upload | export
  sourceId        String?   // ID of the source (e.g. ToolExecution ID)
  description     String?
  tags            String?   // JSON array
  metadata        String?   // JSON: additional metadata
  isPublic        Boolean   @default(false)
  downloadCount   Int       @default(0)
  expiresAt       DateTime? // for temporary files
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  downloads       FileDownload[]
  accessLogs      FileAccessLog[]
  exportJobs      ExportJob[]
  signedUrlTokens SignedUrlToken[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, category])
  @@index([sourceType, sourceId])
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("file_assets")
}

model ExportJob {
  id              String    @id @default(cuid())
  workspaceId     String
  userId          String
  format          String    // pdf | docx | md | zip | json | csv
  sourceType      String    // tool_execution | studio_content | manual | template
  sourceId        String?
  title           String
  description     String?
  status          String    @default("pending") // pending | processing | completed | failed | expired
  fileAssetId     String?   // the generated FileAsset (if successful)
  templateId      String?   // ExportTemplate used (if any)
  options         String?   // JSON: export options (page size, orientation, etc.)
  errorMessage    String?
  attemptCount    Int       @default(0)
  maxAttempts     Int       @default(3)
  startedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime? // export file expiry
  metadata        String?   // JSON: export-specific data
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fileAsset       FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)
  template        ExportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  failureLogs     ExportFailureLog[]

  @@index([workspaceId, status])
  @@index([userId, createdAt])
  @@index([format, status])
  @@index([sourceType, sourceId])
  @@index([createdAt])
  @@map("export_jobs")
}

model ExportTemplate {
  id              String   @id @default(cuid())
  workspaceId     String?
  userId          String?
  name            String
  description     String?
  format          String   // pdf | docx | md | zip
  template        String   // JSON: template definition (layout, styling, placeholders)
  isPublic        Boolean  @default(false)
  isSystem        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  exportJobs      ExportJob[]

  @@index([workspaceId])
  @@index([userId])
  @@index([isPublic])
  @@map("export_templates")
}

model FileDownload {
  id              String   @id @default(cuid())
  fileAssetId     String
  userId          String?
  ipAddress       String?
  userAgent       String?
  signedUrlTokenId String?
  downloadMethod  String   @default("direct") // direct | signed_url | api
  createdAt       DateTime @default(now())

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([fileAssetId, createdAt])
  @@index([userId, createdAt])
  @@map("file_downloads")
}

model FileAccessLog {
  id              String   @id @default(cuid())
  fileAssetId     String
  userId          String?
  action          String   // view | download | delete | signed_url_create | signed_url_use
  ipAddress       String?
  success         Boolean  @default(true)
  errorMessage    String?
  createdAt       DateTime @default(now())

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([fileAssetId, createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("file_access_logs")
}

model ExportFailureLog {
  id              String   @id @default(cuid())
  exportJobId     String
  errorType       String   // generation_error | storage_error | timeout | invalid_input | template_error
  errorMessage    String
  errorCode       String?
  payload         String?  // JSON: context data
  retryCount      Int      @default(0)
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())

  exportJob ExportJob @relation(fields: [exportJobId], references: [id], onDelete: Cascade)

  @@index([exportJobId, createdAt])
  @@index([errorType])
  @@index([resolvedAt])
  @@map("export_failure_logs")
}

model SignedUrlToken {
  id              String   @id @default(cuid())
  fileAssetId     String
  token           String   @unique
  createdBy       String
  expiresAt       DateTime
  downloadLimit   Int      @default(0) // 0 = unlimited
  downloadCount   Int      @default(0)
  ipAddress       String?  // optional IP restriction
  isRevoked       Boolean  @default(false)
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  fileAsset FileAsset @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)

  @@index([fileAssetId])
  @@index([token])
  @@index([expiresAt])
  @@map("signed_url_tokens")
}
