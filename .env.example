# =============================================================================
# Content Smuggler — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values. Never commit .env to version
# control. Variables marked (required) must be set for the app to function.
# All others are optional and default to sensible values or disable the feature.
# =============================================================================

# =============================================================================
# DATABASE  (required)
# =============================================================================
# SQLite (default): "file:../db/custom.db"
# PostgreSQL:       "postgresql://user:password@host:5432/dbname?schema=public"
DATABASE_URL="file:../db/custom.db"

# =============================================================================
# AUTH  (required for production, dev defaults to localhost)
# =============================================================================
# Base URL for NextAuth — used for OAuth redirects and magic links.
# Must match the actual deployment URL in production.
# NEXTAUTH_URL="http://localhost:3000"
# AUTH_URL="http://localhost:3000"       # fallback for NEXTAUTH_URL

# Google OAuth (optional — required for Google login)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# =============================================================================
# AI PROVIDERS  (all optional — ZAI is the default and always available)
# =============================================================================
# ZAI_API_KEY=""                          # default provider (uses SDK credentials)
# AI_DEFAULT_PROVIDER="zai"               # one of: zai | openai | claude | gemini | grok | deepseek
# AI_DEFAULT_MODEL=""                     # model to use when none is specified

# OpenAI
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"

# Anthropic (Claude)
# ANTHROPIC_API_KEY=""
# ANTHROPIC_BASE_URL="https://api.anthropic.com"

# Google Gemini
# GEMINI_API_KEY=""
# GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta"

# xAI (Grok)
# XAI_API_KEY=""
# XAI_BASE_URL="https://api.x.ai/v1"

# DeepSeek
# DEEPSEEK_API_KEY=""
# DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# =============================================================================
# BILLING  (all optional — defaults to free/manual mode)
# =============================================================================
# BILLING_PROVIDER="none"                 # none | stripe | razorpay

# --- Stripe ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PRICE_STARTER_MONTHLY=""
# STRIPE_PRICE_STARTER_YEARLY=""
# STRIPE_PRICE_CREATOR_MONTHLY=""
# STRIPE_PRICE_CREATOR_YEARLY=""
# STRIPE_PRICE_AGENCY_MONTHLY=""
# STRIPE_PRICE_AGENCY_YEARLY=""

# --- Razorpay ---
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""
# RAZORPAY_PLAN_STARTER_MONTHLY=""
# RAZORPAY_PLAN_STARTER_YEARLY=""
# RAZORPAY_PLAN_CREATOR_MONTHLY=""
# RAZORPAY_PLAN_CREATOR_YEARLY=""
# RAZORPAY_PLAN_AGENCY_MONTHLY=""
# RAZORPAY_PLAN_AGENCY_YEARLY=""

# =============================================================================
# FILE STORAGE  (all optional — defaults to local disk)
# =============================================================================
# STORAGE_PROVIDER="local"                # local | s3
# LOCAL_STORAGE_PATH="./storage"          # path for local storage (relative or absolute)
# MAX_UPLOAD_SIZE_BYTES="52428800"        # 50 MB default
# SIGNED_URL_SECRET="change-me"           # secret for signing file URLs

# --- S3 / R2 / MinIO ---
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_BUCKET=""
# S3_ENDPOINT=""                           # optional: for R2/MinIO; omit for AWS S3
# S3_REGION="us-east-1"

# =============================================================================
# NOTIFICATIONS  (all optional — no external notifications sent by default)
# =============================================================================
# EMAIL_FROM="notifications@contentsmuggler.app"

# Email delivery (choose one):
# SMTP_URL=""                              # smtp://user:pass@smtp.example.com:587
# RESEND_API_KEY=""
# SENDGRID_API_KEY=""

# Webhook:
# NOTIFICATION_WEBHOOK_URL=""

# =============================================================================
# LOGGING  (all optional)
# =============================================================================
# LOG_LEVEL="info"                        # debug | info | warn | error
# LOG_SINK_URL=""                         # external log sink (e.g. syslog endpoint)
